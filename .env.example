# ─────────────────────────────────────────────
#  EPS CitaMédica — Variables de Entorno
# ─────────────────────────────────────────────
#  Copia este archivo como .env y completa los valores.
#  NUNCA subas el .env real a GitHub.

# ── Flask ──────────────────────────────────────
FLASK_ENV=development          # production en Render
SECRET_KEY=cambia_esta_clave_secreta_por_una_segura

# ── Base de Datos MySQL (Aiven) ────────────────
# Formato Aiven:  host = xxx.aivencloud.com
MYSQL_HOST=tu-host.aivencloud.com
MYSQL_PORT=3306
MYSQL_USER=avnadmin
MYSQL_PASSWORD=tu_password_aiven
MYSQL_DB=defaultdb

# SSL requerido por Aiven (deja en true en producción)
MYSQL_SSL=true
